# העתיקו ל-.env (או הגדירו בסביבת הפריסה) ושנו לפי הצורך

# פורט השרת (בפריסה לרוב נקבע אוטומטית)
PORT=3000

# מיילים של מנהלים (פאנל ניהול) — מופרדים בפסיק
ADMIN_EMAILS=uv.levari@gmail.com

# נתיב קובץ מסד הנתונים. בפריסה עם דיסק קבוע — הצביעו לתיקיית הדיסק (למשל /data/mondial.db)
DB_PATH=./mondial.db

# ====== שליחת מייל (SMTP) ======
# אם SMTP_USER ו-SMTP_PASS מוגדרים — המערכת שולחת קוד אמיתי במייל.
# אם הם ריקים — המערכת חוזרת אוטומטית למצב הדגמה (קוד על המסך).
#
# ל-Gmail:
#   1. הפעילו אימות דו-שלבי בחשבון Google.
#   2. צרו "App Password" בכתובת https://myaccount.google.com/apppasswords
#   3. הדביקו אותו ב-SMTP_PASS (16 תווים, בלי רווחים).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
# כתובת השולח שתופיע במייל (ברירת מחדל: SMTP_USER)
MAIL_FROM=your@gmail.com

# מצב הדגמה כברירת מחדל כשאין SMTP. אין צורך לשנות — מושבת אוטומטית כשמוגדר מייל.
DEMO_MODE=true

# ====== עדכון תוצאות אוטומטי (API-Football / API-Sports) ======
# מפתח חינמי בהרשמה עצמית: https://dashboard.api-football.com
# אם ריק — העדכון האוטומטי כבוי וההזנה הידנית עובדת כרגיל.
FOOTBALL_API_KEY=
FOOTBALL_API_HOST=v3.football.api-sports.io
WC_LEAGUE_ID=1
WC_SEASON=2026
# כל כמה דקות לבדוק תוצאות אוטומטית (0 = ידני בלבד)
POLL_MINUTES=10
