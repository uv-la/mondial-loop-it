# העתיקו ל-.env (או הגדירו בסביבת הפריסה) ושנו לפי הצורך

# פורט השרת (בפריסה לרוב נקבע אוטומטית)
PORT=3000

# שם המשתמש (כינוי) שיהיה אדמין. אם ריק — המשתמש הראשון שנרשם הופך לאדמין.
ADMIN_USERS=

# נתיב קובץ מסד הנתונים. בפריסה עם דיסק קבוע — הצביעו לתיקיית הדיסק.
DB_PATH=./mondial.db

# ====== עדכון משחקים+תוצאות אוטומטי (API-Football / API-Sports) ======
# מפתח חינמי בהרשמה עצמית: https://dashboard.api-football.com
# אם ריק — העדכון האוטומטי כבוי וההזנה הידנית עובדת כרגיל.
FOOTBALL_API_KEY=
FOOTBALL_API_HOST=v3.football.api-sports.io
WC_LEAGUE_ID=1
WC_SEASON=2026
# כל כמה דקות למשוך משחקים+תוצאות אוטומטית (0 = ידני בלבד). ברירת מחדל: 120 (שעתיים)
POLL_MINUTES=120
